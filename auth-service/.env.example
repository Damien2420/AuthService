# JWT
JWT_SECRET=                          # Base64 編碼的 HMAC 密鑰（至少 256 bit）
JWT_EXPIRATION_MS=300000             # AccessToken 有效期（毫秒），預設 5 分鐘
JWT_REFRESH_EXPIRATION_MS=604800000  # RefreshToken 有效期（毫秒），預設 7 天

# 資料庫
DB_USERNAME=
DB_PASSWORD=

# Google OAuth2 / GIS One Tap
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# LINE OAuth2
LINE_CLIENT_ID=
LINE_CLIENT_SECRET=

# Email（SMTP）
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

# Cloudflare Turnstile（https://dash.cloudflare.com）
TURNSTILE_SECRET_KEY=

# Sentry Tunnel（逗號分隔多個 Project ID，可留空）
SENTRY_ALLOWED_PROJECT_IDS=
